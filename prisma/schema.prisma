generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?       @db.LongText
  password      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  username      String?       @unique
  accounts      Account[]
  books         Book[]
  goals         ReadingGoal[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], map: "accounts_userId_fkey")
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_userId_fkey")
  @@map("sessions")
}

model Category {
  id    String         @id @default(cuid())
  name  String         @unique
  slug  String         @unique
  books BookCategory[]

  @@map("categories")
}

model BookCategory {
  bookId     String
  categoryId String
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([bookId, categoryId])
  @@index([categoryId], map: "book_categories_categoryId_fkey")
  @@map("book_categories")
}

model Book {
  id            String         @id @default(cuid())
  userId        String
  title         String
  author        String
  coverImage    String?        @db.Text
  description   String?        @db.Text
  totalPages    Int?
  currentPage   Int?           @default(0)
  isbn          String?
  publisher     String?
  publishedDate String?
  language      String?        @default("th")
  externalId    String?
  status        ReadingStatus  @default(WANT_TO_READ)
  isFavorite    Boolean        @default(false)
  addedVia      AddedVia       @default(MANUAL)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  categories    BookCategory[]
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  progressLogs  ProgressLog[]
  review        Review?

  @@index([userId])
  @@index([status])
  @@index([externalId])
  @@map("books")
}

model ProgressLog {
  id          String   @id @default(cuid())
  bookId      String
  currentPage Int
  note        String?  @db.Text
  loggedAt    DateTime @default(now())
  book        Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@map("progress_logs")
}

model Review {
  id        String   @id @default(cuid())
  bookId    String   @unique
  rating    Int
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model ReadingGoal {
  id          String     @id @default(cuid())
  userId      String
  period      GoalPeriod @default(YEARLY)
  targetBooks Int
  year        Int
  month       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period, year, month])
  @@map("reading_goals")
}

enum ReadingStatus {
  WANT_TO_READ
  READING
  COMPLETED
  DROPPED
}

enum AddedVia {
  MANUAL
  GOOGLE_BOOKS
  OPEN_LIBRARY
}

enum GoalPeriod {
  MONTHLY
  YEARLY
}